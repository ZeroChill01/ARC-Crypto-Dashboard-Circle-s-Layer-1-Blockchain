def make_price_chart(days_df, vol_df):
    fig = go.Figure()
    if not days_df.empty:
        fig.add_trace(go.Scatter(
            x=days_df["date"], y=days_df["price"],
            mode="lines", name="Ціна",
            line=dict(color=COLORS["accent"], width=2),
            fill="tozeroy",
            fillcolor="rgba(79,142,247,0.08)",
            hovertemplate="<b>%{x|%d %b %Y}</b><br>$%{y:.6f}<extra></extra>",
        ))
    if not vol_df.empty:
        fig.add_trace(go.Bar(
            x=vol_df["date"], y=vol_df["volume"],
            name="Обсяг", yaxis="y2",
            marker_color="rgba(123,92,240,0.35)",
            hovertemplate="Обсяг: $%{y:,.0f}<extra></extra>",
        ))
    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        font=dict(color=COLORS["text"], family="'Inter', sans-serif", size=12),
        legend=dict(orientation="h", y=1.08, x=0, font_size=11,
                    bgcolor="rgba(0,0,0,0)", bordercolor="rgba(0,0,0,0)"),
        margin=dict(l=0, r=0, t=30, b=0),
        xaxis=dict(gridcolor=COLORS["grid"], showline=False, zeroline=False,
                   tickfont=dict(size=11, color=COLORS["text_muted"])),
        yaxis=dict(gridcolor=COLORS["grid"], showline=False, zeroline=False,
                   tickformat="$.6f", tickfont=dict(size=11, color=COLORS["text_muted"]),
                   side="left"),
        yaxis2=dict(overlaying="y", side="right", showgrid=False, zeroline=False,
                    tickformat="$.2s", tickfont=dict(size=10, color=COLORS["text_muted"])),
        hovermode="x unified",
    )
    return fig


def make_ohlc_chart(df):
    fig = go.Figure()
    if not df.empty:
        colors = [COLORS["green"] if c >= o else COLORS["red"]
                  for c, o in zip(df["close"], df["open"])]
        fig.add_trace(go.Candlestick(
            x=df["date"],
            open=df["open"], high=df["high"],
            low=df["low"], close=df["close"],
            increasing_line_color=COLORS["green"],
            decreasing_line_color=COLORS["red"],
            name="OHLC",
        ))
    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        font=dict(color=COLORS["text"], family="'Inter', sans-serif", size=12),
        margin=dict(l=0, r=0, t=10, b=0),
        xaxis=dict(gridcolor=COLORS["grid"], showline=False, zeroline=False, rangeslider=dict(visible=False),
                   tickfont=dict(size=11, color=COLORS["text_muted"])),
        yaxis=dict(gridcolor=COLORS["grid"], showline=False, zeroline=False,
                   tickformat="$.7f", tickfont=dict(size=11, color=COLORS["text_muted"])),
        xaxis_rangeslider_visible=False,
    )
    return fig


def make_gauge(change_pct):
    abs_val = abs(change_pct)
    sentiment = "BULLISH" if change_pct >= 0 else "BEARISH"
    color = COLORS["green"] if change_pct >= 0 else COLORS["red"]
    fig = go.Figure(go.Indicator(
        mode="gauge+number",
        value=50 + min(change_pct * 2, 48),   # normalize to 0-100
        number=dict(suffix="%", valueformat="+.2f",
                    font=dict(color=color, size=28, family="'Space Mono', monospace")),
        gauge=dict(
            axis=dict(range=[0, 100], tickwidth=0, tickcolor="rgba(0,0,0,0)"),
            bar=dict(color=color, thickness=0.2),
            bgcolor="rgba(0,0,0,0)",
            borderwidth=0,
            steps=[
                dict(range=[0, 20], color="rgba(239,68,68,0.15)"),
                dict(range=[20, 45], color="rgba(239,68,68,0.08)"),
                dict(range=[45, 55], color="rgba(107,122,153,0.08)"),
                dict(range=[55, 80], color="rgba(34,197,94,0.08)"),
                dict(range=[80, 100], color="rgba(34,197,94,0.15)"),
            ],
            threshold=dict(line=dict(color=color, width=3), thickness=0.8, value=50 + min(change_pct * 2, 48)),
        ),
        title=dict(text=f"<b>{sentiment}</b>", font=dict(size=13, color=color)),
        domain=dict(x=[0, 1], y=[0, 1]),
    ))
    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        margin=dict(l=20, r=20, t=30, b=10),
        height=180,
        font=dict(color=COLORS["text"]),
    )
    return fig


