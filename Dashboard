def fmt_usd(value, decimals=6):
    if value is None or value == 0:
        return "$0"
    if value >= 1e9:
        return f"${value/1e9:.2f}B"
    if value >= 1e6:
        return f"${value/1e6:.2f}M"
    if value >= 1e3:
        return f"${value/1e3:.2f}K"
    return f"${value:.{decimals}f}"


def pct_color(val):
    return COLORS["green"] if val >= 0 else COLORS["red"]


