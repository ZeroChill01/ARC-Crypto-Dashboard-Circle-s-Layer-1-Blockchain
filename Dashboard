@app.callback(
    Output("kpi-row", "children"),
    Output("price-chart", "figure"),
    Output("ohlc-chart", "figure"),
    Output("sentiment-gauge", "figure"),
    Output("arc-info-block", "children"),
    Output("last-updated", "children"),
    Input("auto-refresh", "n_intervals"),
    Input("refresh-btn", "n_clicks"),
    Input("period-selector", "value"),
)
def update_all(_, __, days):
    price_data = fetch_price_data()
    prices_df, vol_df = fetch_market_chart(days=days)
    ohlc_df = fetch_ohlc(days=min(days, 30))

    price = price_data.get("price", 0)
    change = price_data.get("change_24h", 0)
    mcap = price_data.get("market_cap", 0)
    vol = price_data.get("volume_24h", 0)
    change_sign = "▲" if change >= 0 else "▼"
    change_color = pct_color(change)

    # KPI cards
    kpi = [
        make_kpi_card("Ціна ARC", fmt_usd(price),
                      f"{change_sign} {abs(change):.2f}% за 24г", change_color),
        make_kpi_card("Ринкова капіталізація", fmt_usd(mcap),
                      "Загальна вартість ринку"),
        make_kpi_card("Обсяг 24г", fmt_usd(vol),
                      "Торговий обсяг за добу"),
        make_kpi_card("Зміна 24г", f"{change_sign} {abs(change):.2f}%",
                      "Відносна зміна ціни", change_color),
    ]

    # Gauge info
    ratio = vol / mcap if mcap > 0 else 0
    info_block = html.Div([
        html.Div([
            html.Span("Vol/MCap", style={"fontSize": "11px", "color": COLORS["text_muted"]}),
            html.Span(f"{ratio:.2%}", style={"fontSize": "12px", "fontWeight": "600",
                                               "color": COLORS["accent2"],
                                               "fontFamily": "'Space Mono', monospace",
                                               "float": "right"}),
        ], style={"borderBottom": f"1px solid {COLORS['border']}", "paddingBottom": "8px", "marginBottom": "8px"}),
        html.P("Активність ринку: "
               + ("Висока 🔥" if ratio > 0.1 else "Середня ⚡" if ratio > 0.03 else "Низька 💤"),
               style={"fontSize": "11px", "color": COLORS["text_muted"], "margin": 0}),
    ])

    ts = datetime.now().strftime("%H:%M:%S")

    return (kpi,
            make_price_chart(prices_df, vol_df),
            make_ohlc_chart(ohlc_df),
            make_gauge(change),
            info_block,
            f"Оновлено: {ts}")


